# Copy this to .env and fill in. .env is git-ignored.
# First-time-only: visit http://<host>:5000/colab-setup from your Pixel
# to seed Colab cookies.

# === IB Gateway ===
# IBKR account username -- REQUIRED
IB_USERNAME=fiend6969
# IBKR account password -- REQUIRED (overrides compose default)
IB_PASSWORD=change-me
# IBKR region (Americas/Europe/Asia) -- OPTIONAL
IB_REGION=America
# IBKR Java client timezone -- OPTIONAL
IB_TIMEZONE=America/Vancouver
# ibga login tab selector -- OPTIONAL
IB_LOGINTAB=IB API
# Live Trading vs Paper Trading -- OPTIONAL
IB_LOGINTYPE=Live Trading
# Force IBKey 2FA push (vs SMS) -- OPTIONAL
IB_PREFER_IBKEY=true
# Internal IB Gateway API port -- OPTIONAL
IBG_PORT_INTERNAL=4001
# URL backend uses to hit IB Gateway -- OPTIONAL
IB_GATEWAY_URL=http://localhost:4001
# Seconds ibga waits for gateway boot -- OPTIONAL
IBGA_WAIT_TIMEOUT=600

# === ngrok ===
# ngrok auth token from dashboard -- REQUIRED for remote Colab access
NGROK_AUTHTOKEN=your-token-here
# Reserved ngrok domain (free or paid) -- OPTIONAL
NGROK_DOMAIN=copyrightable-pseudocartilaginous-sade.ngrok-free.dev

# === Ollama ===
# Bind address for Ollama server -- OPTIONAL
OLLAMA_HOST=0.0.0.0:11434
# URL backend uses to reach Ollama -- OPTIONAL
OLLAMA_URL=http://localhost:11434
# Comma-separated models to pull at boot -- OPTIONAL
OLLAMA_MODELS=llama3.1:8b
# Default model name for parallel workers -- OPTIONAL
OLLAMA_MODEL=gemma4:31b-cloud
# Concurrent requests per loaded model -- OPTIONAL
OLLAMA_NUM_PARALLEL=2
# Max models kept hot in VRAM -- OPTIONAL
OLLAMA_MAX_LOADED_MODELS=2

# === Colab / Google ===
# OAuth refresh token for Google APIs -- OPTIONAL (service-account flow only)
GOOGLE_REFRESH_TOKEN=your-token-here
# OAuth client ID -- OPTIONAL
GOOGLE_CLIENT_ID=your-client-id-here
# OAuth client secret -- OPTIONAL
GOOGLE_CLIENT_SECRET=your-client-secret-here
# Drive file ID of the Colab notebook -- OPTIONAL
COLAB_NOTEBOOK_DRIVE_ID=xxx
# Path where Playwright stores Colab cookies -- OPTIONAL
COLAB_AUTH_STATE=/app/data/colab_state.json

# === Backend / LLM ===
# OpenRouter API key for hosted LLM calls -- REQUIRED if LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your-key-here
# Which LLM provider the backend uses -- OPTIONAL
LLM_PROVIDER=openrouter
# GitHub PAT used by scanner to push reports -- OPTIONAL
GITHUB_TOKEN=your-token-here
# URL the scanner posts Colab jobs to -- OPTIONAL
ORACLE_EXECUTOR_URL=http://localhost:5000
# Python import root inside container -- OPTIONAL
PYTHONPATH=/app
# Log verbosity (DEBUG/INFO/WARN/ERROR) -- OPTIONAL
LOG_LEVEL=INFO
# Path to log file -- OPTIONAL
LOG_FILE=/tmp/arbitrage.log
# Kalshi REST API base URL -- OPTIONAL
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
# Robinhood OAuth client ID -- OPTIONAL
ROBINHOOD_CLIENT_ID=
# Robinhood signing key (PEM) -- OPTIONAL
ROBINHOOD_PRIVATE_KEY=

# === Universal entrypoint tuning ===
# Terminal type for ibga Java UI -- OPTIONAL
TERM=xterm
# Seconds between IBKey 2FA push retries -- OPTIONAL
TWO_FA_WINDOW=120
# Max 2FA push attempts before giving up -- OPTIONAL
MAX_2FA_RETRIES=5
